# =============================================================================
# Brewfile — DEPRECATED: use brew/ directory instead
# =============================================================================
# This file is kept for backward compatibility.
# The canonical Brewfiles are now split by concern:
#
#   brew/Brewfile.base      — Core packages (all profiles, all modes)
#   brew/Brewfile.cli       — CLI tools (brew-only mode; Nix manages these otherwise)
#   brew/Brewfile.personal  — Personal profile additions
#   brew/Brewfile.work      — Work profile additions
#   brew/Brewfile.openclaw  — OpenClaw profile additions
#
# To install manually:
#   brew bundle --file=brew/Brewfile.base
#   brew bundle --file=brew/Brewfile.<profile>
#
# Or use the installer:
#   ./install.sh --hostname <host> --mode brew
# =============================================================================
