# secrets.yaml.example — Template for SOPS-encrypted secrets
# Copy this file to secrets/secrets.yaml and encrypt with:
#   sops --encrypt --in-place secrets/secrets.yaml
#
# To edit:
#   sops secrets/secrets.yaml

# Git configuration
git_user_name: "Your Name"
git_user_email: "you@example.com"
git_signing_key: "YOUR_GPG_KEY_ID"

# GitHub
github_personal_access_token: "ghp_REPLACE_ME"

# AWS (optional)
# aws_access_key_id: ""
# aws_secret_access_key: ""

# Grafana (optional)
# grafana_url: "https://your-grafana.example.com"
# grafana_service_account_token: ""
